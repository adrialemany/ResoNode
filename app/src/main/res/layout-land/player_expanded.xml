<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/player_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- Fondos (requeridos por miniSet/fullSet) -->
    <View
        android:id="@+id/bg_full"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#121212"
        android:alpha="1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bg_mini"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardBackgroundColor="#121212"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ============================================================
         NOTA: NO se usan Guidelines aquí porque no existen en
         playerRoot (activity_main.xml). Toda la lógica de split
         izquierda/derecha se hace con constraintWidth_percent en la
         carátula y start_toEndOf="iv_cover" en el resto de elementos.
         ============================================================ -->

    <!-- Botón cerrar: esquina superior izquierda -->
    <ImageButton
        android:id="@+id/btn_close_player"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="4dp"
        android:rotation="90"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:scaleType="centerInside"
        app:srcCompat="@android:drawable/ic_menu_revert"
        app:tint="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ===== CARÁTULA =====
         Ocupa el 38% izquierdo de la pantalla (constraintWidth_percent).
         Con ratio 1:1 queda cuadrada. Centrada verticalmente con márgenes.
         El resto de elementos se anclan a start_toEndOf="iv_cover". -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_cover"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="58dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="14dp"
        android:scaleType="centerCrop"
        android:elevation="8dp"
        app:shapeAppearanceOverlay="@style/RoundedAppearance24dp"
        app:layout_constraintWidth_percent="0.35"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintHorizontal_bias="0.0" />

    <!-- ===== PANEL DERECHO =====
         Todos los elementos usan start_toEndOf="@id/iv_cover" para
         anclar al borde derecho de la carátula (que sí existe en playerRoot). -->

    <!-- Título: arriba del panel derecho, pegado al borde superior con margen -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="65dp"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_artist"
        app:layout_constraintStart_toEndOf="@id/iv_cover"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.0" />

    <!-- Artista: justo debajo del título -->
    <TextView
        android:id="@+id/tv_artist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="4dp"
        android:textColor="#AAAAAA"
        android:textSize="18sp"
        android:singleLine="true"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toEndOf="@id/iv_cover"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- SeekBar: centrada verticalmente entre tv_artist y los botones.
         Ancho completo del panel derecho (de iv_cover al borde derecho). -->
    <SeekBar
        android:id="@+id/seek_bar"
        android:layout_width="0dp"
        android:layout_height="36dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_play"
        app:layout_constraintStart_toEndOf="@id/iv_cover"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.8" />

    <!-- Tiempo actual: debajo del seekbar, izquierda -->
    <TextView
        android:id="@+id/tv_current_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="4dp"
        android:textColor="#80FFFFFF"
        android:textSize="11sp"
        app:layout_constraintTop_toBottomOf="@id/seek_bar"
        app:layout_constraintStart_toEndOf="@id/iv_cover" />

    <!-- Tiempo total: debajo del seekbar, derecha -->
    <TextView
        android:id="@+id/tv_total_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="4dp"
        android:textColor="#80FFFFFF"
        android:textSize="11sp"
        app:layout_constraintTop_toBottomOf="@id/seek_bar"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ===== BOTONES: cadena horizontal spread_inside =====
         Anclados entre iv_cover (start) y borde derecho (end).
         Verticalmente: pegados al fondo con margen.
         Java sobreescribe: btn_play=100dp, btn_prev/next=70dp.
         Con spread_inside los 5 botones se distribuyen automáticamente
         dentro del espacio disponible sin salirse de la pantalla. -->

    <ImageButton
        android:id="@+id/btn_repeat"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_repeat_one"
        android:scaleType="fitCenter"
        android:padding="10dp"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.88"
        app:layout_constraintStart_toEndOf="@id/iv_cover"
        app:layout_constraintEnd_toStartOf="@id/btn_prev"
        app:layout_constraintHorizontal_chainStyle="spread_inside" />

    <ImageButton
        android:id="@+id/btn_prev"
        android:layout_width="65dp"
        android:layout_height="65dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:scaleType="fitCenter"
        android:padding="0dp"
        app:layout_constraintBottom_toBottomOf="@id/btn_repeat"
        app:layout_constraintTop_toTopOf="@id/btn_repeat"
        app:layout_constraintStart_toEndOf="@id/btn_repeat"
        app:layout_constraintEnd_toStartOf="@id/btn_play" />

    <ImageButton
        android:id="@+id/btn_play"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:scaleType="fitCenter"
        android:padding="0dp"
        app:layout_constraintBottom_toBottomOf="@id/btn_repeat"
        app:layout_constraintTop_toTopOf="@id/btn_repeat"
        app:layout_constraintStart_toEndOf="@id/btn_prev"
        app:layout_constraintEnd_toStartOf="@id/btn_next" />

    <ImageButton
        android:id="@+id/btn_next"
        android:layout_width="65dp"
        android:layout_height="65dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:scaleType="fitCenter"
        android:padding="0dp"
        app:layout_constraintBottom_toBottomOf="@id/btn_repeat"
        app:layout_constraintTop_toTopOf="@id/btn_repeat"
        app:layout_constraintStart_toEndOf="@id/btn_play"
        app:layout_constraintEnd_toStartOf="@id/btn_shuffle" />

    <ImageButton
        android:id="@+id/btn_shuffle"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:visibility="visible"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_shuffle"
        android:scaleType="fitCenter"
        android:padding="10dp"
        app:layout_constraintBottom_toBottomOf="@id/btn_repeat"
        app:layout_constraintTop_toTopOf="@id/btn_repeat"
        app:layout_constraintStart_toEndOf="@id/btn_next"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>